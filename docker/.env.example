# --- 必填 ---
# Postgres 密码（任意强密码）
POSTGRES_PASSWORD=please-change-me
# JWT 签名密钥（≥ 32 字符；可以 openssl rand -hex 32）
JWT_SECRET=please-change-me-to-a-32-plus-char-random-string

# --- 端口 / 可选 ---
# 前端对外暴露的端口（浏览器访问）
HTTP_PORT=3000

# Postgres 名称、用户（一般不改）
POSTGRES_DB=rag
POSTGRES_USER=rag

# 本地模型选择（HuggingFace repo id，需要支持 ONNX）
EMBEDDING_MODEL=Xenova/bge-base-zh-v1.5
RERANKER_MODEL=Xenova/bge-reranker-base

# 上传与切分参数
MAX_UPLOAD_MB=50
MAX_CHUNKS_PER_DOC=5000
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# 公开召回接口的 IP 限流（每分钟次数）
RETRIEVE_RATE_PER_MIN=60

# JWT 有效期
JWT_EXPIRES_IN=7d

# 日志级别 (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info
